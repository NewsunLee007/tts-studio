{
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=/api/:path*"
    },
    {
      "source": "/audio/:path*",
      "destination": "/api?path=/audio/:path*"
    },
    {
      "source": "/exports/:path*",
      "destination": "/api?path=/exports/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
